// src/store/index.js
import Vue from 'vue';
import Vuex from 'vuex';

Vue.use(Vuex);

export default new Vuex.Store({
  state: {
    // Estado global: Carrinho de compras
    cart: [],
    // Exemplo de produtos (inventário)
    products: [
      { id: 1, name: 'Produto A', price: 100 },
      { id: 2, name: 'Produto B', price: 150 }
    ]
  },
  mutations: {
    // Mutations para modificar o estado (Síncronas)
    ADD_TO_CART(state, product) {
      state.cart.push(product);
    },
  },
  actions: {
    // Ações para lidar com lógica e chamar mutations (Assíncronas/Síncronas)
    addToCart({ commit }, product) {
      commit('ADD_TO_CART', product);
    },
  },
  getters: {
    // Getters para acessar o estado processado
    cartItemCount: state => {
      return state.cart.length;
    },
    cartTotal: state => {
      return state.cart.reduce((total, product) => total + product.price, 0);
    }
  }
});
